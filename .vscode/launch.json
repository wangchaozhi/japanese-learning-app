{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Debug Local YML",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/server",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "APP_ENV": "local",
        "CONFIG_FILE": "${workspaceFolder}/backend/configs/local.yml"
      }
    },
    {
      "name": "Backend: Debug Dev YML",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/server",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "APP_ENV": "dev",
        "CONFIG_FILE": "${workspaceFolder}/backend/configs/dev.yml"
      }
    },
    {
      "name": "Backend: Debug Prod YML",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/server",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "APP_ENV": "prod",
        "CONFIG_FILE": "${workspaceFolder}/backend/configs/prod.yml"
      }
    },
    {
      "name": "Admin: npm run dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --host 0.0.0.0",
      "cwd": "${workspaceFolder}/front/admin"
    }
  ]
}
